#!/usr/bin/env sh

set -eu

script_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
repo_root="$(dirname -- "$script_dir")"

if [ -z "${PYTHONPATH:-}" ]; then
  export PYTHONPATH="${repo_root}/src"
else
  export PYTHONPATH="${repo_root}/src:${PYTHONPATH}"
fi

exec python3 -m glpi_agents_sync "$@"
