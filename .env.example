# Credenciais do ambiente GLPI local
# Copie este arquivo para .env e preencha com os valores reais
# Nunca commite o .env — ele está no .gitignore

glpi-app-token=
glpi-user-token=
glpi-api=http://localhost:8080/
glpi-api-version=all   # legacy=old | newest=new | all=both
glpi-user=
glpi-pass=

# OpenRouter (usado pelos agentes que consomem LLM diretamente)
openrouter-api=
openrouter-model=openrouter/free
